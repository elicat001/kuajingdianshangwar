NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ai_commerce_war

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# JWT — MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_SECONDS=86400

# Logging
LOG_LEVEL=info

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3001

# S3/OSS (optional)
S3_BUCKET=ai-commerce-war
S3_REGION=us-east-1
